{
  "name": "piaf",
  "version": "1.0.0",
  "description": "```sh ./build_for_pi.sh ```",
  "main": "index.js",
  "scripts": {
    "install_icons": "rm -rf src/assets/bootstrap-icons; cp -r node_modules/bootstrap-icons/font ./src/assets/bootstrap-icons",
    "make_css": "sass src/styles/piaf.scss src/assets/piaf.css --style=compressed --load-path=node_modules --quiet-deps --silence-deprecation=import",
    "make_css_w": "sass -w src/styles/piaf.scss src/assets/piaf.css --style=compressed --load-path=node_modules --quiet-deps --silence-deprecation=import",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "bootswatch": "^5.3.7"
  }
}
