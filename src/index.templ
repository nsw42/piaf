<!DOCTYPE html>
<html>
<head>
<link href="/assets/bootstrap.min.css" rel="stylesheet">
<script src="/assets/bootstrap.bundle.min.js"></script>
</head>
<body>
<h1>{{.RequestPath}}</h1>
<ul>
{{/* directories first */}}
{{- if ne .RequestPath "/" -}}
<li><a href="..">(up)</a></li>
{{end}}

{{- range .MediaDir.SubDirectories }}
<li><a href="/media/{{.RelativePath}}/">{{.Leaf}}</a></li>
{{- end -}}

{{- range .MediaDir.Files }}
<li>{{.DisplayName}} ({{.Duration}})</li>
{{- end }}
</ul>
</body>
</html>
